{
  "id": "legal-data",
  "name": "Legal Data Plugin for OpenClaw",
  "description": "Legal data plugin for OpenClaw — real regulations from 66 official sources across 100+ countries. GDPR, customs/HS codes, sanctions, dual-use, EAEU, GOST. Stops your agent from hallucinating legal citations.",
  "version": "1.0.0",
  "homepage": "https://legaldata-public.cleolabs.co",
  "license": "MIT-0",
  "skills": [
    "skills/regulatory-research",
    "skills/gdpr-data-protection",
    "skills/customs-hs-classifier",
    "skills/dual-use-export-control",
    "skills/sanctions-screening"
  ],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["CLEO_LEGAL_API_KEY"],
    "properties": {
      "CLEO_LEGAL_API_KEY": {
        "type": "string",
        "pattern": "^ld_live_[a-zA-Z0-9]{16,}$",
        "description": "Cleo Legal API key (format: ld_live_...). Get one at https://legaldata-public.cleolabs.co/signup"
      },
      "CLEO_LEGAL_MCP_URL": {
        "type": "string",
        "format": "uri",
        "default": "https://api.legaldata.cleolabs.co/mcp",
        "description": "Override MCP server URL (default: production)"
      }
    }
  },
  "setup": {
    "providers": [
      {
        "name": "cleo-legal-signup",
        "description": "Open legaldata-public.cleolabs.co/signup in browser to obtain an API key",
        "url": "https://legaldata-public.cleolabs.co/signup?utm_source=clawhub&utm_medium=cli&utm_campaign=clawhub-setup",
        "envVar": "CLEO_LEGAL_API_KEY"
      }
    ]
  },
  "keywords": [
    "openclaw-plugin",
    "clawhub",
    "mcp",
    "legal",
    "regulatory",
    "compliance",
    "gdpr",
    "ccpa",
    "lgpd",
    "pipl",
    "customs",
    "hs-code",
    "tn-ved",
    "sanctions",
    "ofac",
    "dual-use",
    "wassenaar",
    "kyc",
    "aml",
    "eaeu",
    "gost",
    "anti-hallucination"
  ]
}
