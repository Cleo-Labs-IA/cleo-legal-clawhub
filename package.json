{
  "name": "@alexbloch-ia/legal-data",
  "version": "1.0.0",
  "description": "Legal data plugin for OpenClaw — 66 official sources across 100+ countries.",
  "license": "MIT-0",
  "type": "module",
  "homepage": "https://legaldata-public.cleolabs.co",
  "repository": {
    "type": "git",
    "url": "https://github.com/AlexBloch-IA/cleo-legal-clawhub"
  },
  "bugs": {
    "url": "https://github.com/AlexBloch-IA/cleo-legal-clawhub/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist/**",
    "openclaw.plugin.json",
    ".claude-plugin",
    "commands",
    "skills",
    ".mcp.json",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "openclaw": {
    "extensions": ["./dist/index.js"],
    "compat": { "pluginApi": "1.x" },
    "build":  { "openclawVersion": "1.x" }
  },
  "keywords": [
    "openclaw-plugin",
    "mcp",
    "legal",
    "regulatory",
    "compliance",
    "gdpr",
    "customs",
    "hs-code",
    "sanctions",
    "ofac",
    "dual-use",
    "wassenaar",
    "kyc",
    "aml",
    "eaeu",
    "gost"
  ]
}
